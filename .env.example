# EduMind AI — copy to .env.local for local development.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database demo data can remain enabled while real AI is used.
DEMO_MODE=true
AI_DEMO_MODE=false

# AI provider: ollama | openai-compatible | openai | vllm | gemini | anthropic
LLM_PROVIDER=ollama

# Ollama local example: http://localhost:11434
# OpenAI-compatible example: https://api.openai.com/v1
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_MODEL=qwen3:4b
LLM_FAST_MODEL=qwen3:4b
LLM_DEEP_MODEL=qwen3:8b
LLM_TIMEOUT_MS=180000
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=4096

# Anthropic alternative
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings / RAG
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

# Rate limiting
AI_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_MS=3600000
